# Required: The URL to forward callbacks to
FORWARD_URL=https://your-backend-api.com

# Optional: Server listen address (default: :8080)
LISTEN_ADDR=:8080

# Optional: Timeout for forwarding requests (default: 30s)
FORWARD_TIMEOUT=30s

# Optional: Maximum retry attempts for failed forwards (default: 3)
MAX_RETRIES=3

# Optional: Delay between retries (default: 1s)
RETRY_DELAY=1s

# Optional: Number of worker goroutines (default: 10)
WORKER_COUNT=10

# Optional: Number of retry worker goroutines (default: 5)
RETRY_WORKER_COUNT=5

# Optional: Maximum queue size (default: 10000)
QUEUE_SIZE=10000

# Optional: Maximum retry queue size (default: 5000)
RETRY_QUEUE_SIZE=5000

# Optional: Request time-to-live before expiration (default: 5m)
REQUEST_TTL=5m

# Optional: Maximum request body size in bytes (default: 10485760 = 10MB)
MAX_BODY_SIZE=10485760

# Optional: Enable request deduplication (default: true)
ENABLE_DEDUPE=true

# Optional: Deduplication window duration (default: 5m)
DEDUPE_WINDOW=5m

# Optional: Enable queue persistence to disk (default: false)
ENABLE_PERSISTENCE=false

# Optional: Path for queue persistence file (default: /tmp/glo-traffic-queue.json)
PERSISTENCE_PATH=/tmp/glo-traffic-queue.json

# Optional: Enable Dead Letter Queue for failed requests (default: true)
ENABLE_DLQ=true

# Optional: Path for DLQ file (default: /tmp/glo-traffic-dlq.json)
DLQ_PATH=/tmp/glo-traffic-dlq.json

# Optional: Maximum DLQ size (default: 10000)
DLQ_MAX_SIZE=10000

# Optional: Enable circuit breaker (default: true)
CIRCUIT_BREAKER_ENABLED=true

# Optional: Circuit breaker failure threshold (default: 5)
CIRCUIT_BREAKER_THRESHOLD=5

# Optional: Circuit breaker timeout before retry (default: 60s)
CIRCUIT_BREAKER_TIMEOUT=60s

# Optional: Memory alert threshold in bytes (default: 524288000 = 500MB)
MEMORY_ALERT_THRESHOLD=524288000
